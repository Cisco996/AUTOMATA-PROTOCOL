# =============================================================
# Automata Protocol V6 - Environment Configuration
# =============================================================
# Copy this file to ".env.local" and fill in your values.
# Place this file in: dashboard_nextjs/
# =============================================================

# ── Blockchain ──────────────────────────────────────────────
# ID of the Move package deployed on IOTA testnet
PACKAGE_ID=0xYOUR_PACKAGE_ID_HERE

# ID of the OracleRegistry shared object on-chain
REGISTRY_ID=0xYOUR_REGISTRY_ID_HERE

# RPC endpoint for IOTA testnet node
RPC_URL=https://api.testnet.iota.cafe

# Move module name (do not change unless redesigning contract)
MODULE_NAME=notarizer_v2

# ── OLT On-Chain Objects (20 OLTs) ──────────────────────────
# JSON map: olt_id (1-20) -> ObjectID on-chain
OLT_OBJECT_IDS={"1": "0x...", "2": "0x...", "3": "0x...", "4": "0x...", "5": "0x...", "6": "0x...", "7": "0x...", "8": "0x...", "9": "0x...", "10": "0x...", "11": "0x...", "12": "0x...", "13": "0x...", "14": "0x...", "15": "0x...", "16": "0x...", "17": "0x...", "18": "0x...", "19": "0x...", "20": "0x..."}

# ── Simulation / Oracle ─────────────────────────────────────
# SNMP silence seconds before OLT is marked offline (default: 70)
TIMEOUT_LIMIT=70

# ── Oracle Keys ─────────────────────────────────────────────
# JSON map: oracle_id (1-10) -> IOTA Private Key
# WARNING: Never commit real keys to version control!
ORACLE_KEYS={"1":"iotaprivkey1...","2":"iotaprivkey1...","3":"iotaprivkey1...","4":"iotaprivkey1...","5":"iotaprivkey1...","6":"iotaprivkey1...","7":"iotaprivkey1...","8":"iotaprivkey1...","9":"iotaprivkey1...","10":"iotaprivkey1..."}
